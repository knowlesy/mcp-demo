<file path="ansible/playbooks/fix-db-corruption.yaml">
---
# Fix Scenario 5: Restore the SQLite database after table corruption.
# Strategy: exec into the pod and re-run the init_db() SQL, then seed data.
- name: Fix DB Corruption — restore SQLite tables
  hosts: local
  gather_facts: false
  vars:
    db_path: /data/app.db

  tasks:
    - name: Confirm /health is returning 500
      uri:
        url: "{{ app_url }}/health"
        method: GET
        status_code: 500
      register: health_pre
      ignore_errors: true

    - name: Show pre-fix health status
      debug:
        msg: "Pre-fix health status: {{ health_pre.status | default('connection error') }}"

    - name: Get dummy-webapp pod name
      command: >
        kubectl get pod -n {{ app_namespace }} -l app=dummy-webapp
        -o jsonpath='{.items[0].metadata.name}'
      register: pod_name
      changed_when: false

    - name: Restore SQLite schema and seed data via exec
      command: >
        kubectl exec -n {{ app_namespace }} {{ pod_name.stdout }}
        -- python3 -c "
import sqlite3, os
db = os.environ.get('DB_PATH', '{{ db_path }}')
conn = sqlite3.connect(db)
conn.executescript('''
  CREATE TABLE IF NOT EXISTS users (
      id         INTEGER PRIMARY KEY AUTOINCREMENT,
      name       TEXT    NOT NULL,
      email      TEXT    UNIQUE NOT NULL,
      created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
  );
  CREATE TABLE IF NOT EXISTS events (
      id         INTEGER PRIMARY KEY AUTOINCREMENT,
      user_id    INTEGER,
      action     TEXT,
      timestamp  TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
      FOREIGN KEY (user_id) REFERENCES users(id)
  );
''')
try:
    conn.execute(\"INSERT INTO users (name, email) VALUES ('Admin', 'admin@example.com')\")
    conn.execute(\"INSERT INTO users (name, email) VALUES ('Alice', 'alice@example.com')\")
    conn.commit()
except Exception as e:
    print(f'Seed note: {e}')
rows = conn.execute('SELECT COUNT(*) FROM users').fetchone()
conn.close()
print(f'Restore complete. users row count: {rows[0]}')
"
      register: restore_result

    - name: Show restore output
      debug:
        msg: "{{ restore_result.stdout }}"

    - name: Verify health is 200
      uri:
        url: "{{ app_url }}/health"
        method: GET
        status_code: 200
      retries: 6
      delay: 5
      register: health_post

    - name: Verify /users returns data
      uri:
        url: "{{ app_url }}/users"
        method: GET
        status_code: 200
      register: users_result

    - name: Report success
      debug:
        msg: >
          DB restored successfully.
          Health: {{ health_post.json }}.
          Users in DB: {{ users_result.json | length }}
</file>

<file path="ansible/playbooks/fix-nginx-whitelist.yaml">
---
# Fix Scenario 3: Remove the restrictive nginx whitelist annotation.
- name: Fix Nginx Whitelist — remove IP restriction
  hosts: local
  gather_facts: false

  tasks:
    - name: Read current Ingress annotations
      command: >
        kubectl get ingress dummy-webapp -n {{ app_namespace }}
        -o jsonpath='{.metadata.annotations}'
      register: ingress_annotations
      changed_when: false

    - name: Display current annotations
      debug:
        msg: "Current annotations: {{ ingress_annotations.stdout }}"

    - name: Remove whitelist-source-range annotation
      command: >
        kubectl annotate ingress dummy-webapp -n {{ app_namespace }}
        nginx.ingress.kubernetes.io/whitelist-source-range-
      register: annotate_result
      failed_when:
        - annotate_result.rc != 0
        - '"not found" not in annotate_result.stderr'

    - name: Wait for nginx controller to reload (5s)
      pause:
        seconds: 5

    - name: Verify access is restored
      uri:
        url: "{{ app_url }}/"
        method: GET
        status_code: 200
      retries: 5
      delay: 3
      register: access_check

    - name: Report
      debug:
        msg: "Nginx whitelist removed. App is accessible again: {{ access_check.status }}"
</file>

<file path="ansible/playbooks/fix-oom.yaml">
---
# Fix Scenario 1: OOM Kill
# Raises the memory limit on dummy-webapp from 256Mi to 512Mi,
# commits the change to Gitea, and triggers an ArgoCD sync.
- name: Fix OOM Kill — raise memory limits
  hosts: local
  gather_facts: false
  vars:
    manifest_path: "{{ playbook_dir }}/../../apps/dummy-webapp/k8s/deployment.yaml"
    new_limit: "512Mi"
    argocd_app: "dummy-webapp"

  tasks:
    - name: Confirm OOMKilled status
      command: >
        kubectl get pod -n {{ app_namespace }} -l app=dummy-webapp
        -o jsonpath='{.items[0].status.containerStatuses[0].lastState.terminated.reason}'
      register: oom_reason
      changed_when: false

    - name: Display termination reason
      debug:
        msg: "Last termination reason: {{ oom_reason.stdout }}"

    - name: Patch memory limit in deployment manifest
      replace:
        path: "{{ manifest_path }}"
        regexp: '(memory: )256Mi(\s+# intentionally low.*)'
        replace: '\g<1>{{ new_limit }}\2'

    - name: Commit updated manifest
      shell: |
        git add {{ manifest_path }}
        git commit -m "fix(oom): raise memory limit to {{ new_limit }}"
      args:
        chdir: "{{ playbook_dir }}/../../"

    - name: Push to Gitea
      shell: |
        bash scripts/push-to-gitea.sh
      args:
        chdir: "{{ playbook_dir }}/../../"

    - name: Trigger ArgoCD sync
      command: >
        argocd app sync {{ argocd_app }} --grpc-web --insecure
      ignore_errors: true

    - name: Wait for ArgoCD sync to complete
      command: >
        argocd app wait {{ argocd_app }} --sync --health --timeout 120 --grpc-web --insecure
      ignore_errors: true

    - name: Verify health endpoint
      uri:
        url: "{{ app_url }}/health"
        method: GET
        status_code: 200
      retries: 10
      delay: 10
      register: health_result

    - name: Report fix result
      debug:
        msg: "dummy-webapp is healthy after OOM fix: {{ health_result.json }}"
</file>

<file path="ansible/playbooks/fix-rundeck-chaos.yaml">
---
# Fix Scenario 2: Rundeck deleted the dummy-webapp Deployment.
# Re-applies the k8s manifests directly and then lets ArgoCD take over.
- name: Fix Rundeck Chaos — restore deleted deployment
  hosts: local
  gather_facts: false
  vars:
    k8s_manifest_dir: "{{ playbook_dir }}/../../apps/dummy-webapp/k8s"
    argocd_app: "dummy-webapp"

  tasks:
    - name: Check if deployment exists
      command: kubectl get deployment dummy-webapp -n {{ app_namespace }}
      register: dep_check
      failed_when: false
      changed_when: false

    - name: Show deployment status
      debug:
        msg: "{{ dep_check.stderr if dep_check.rc != 0 else 'Deployment exists (may have been restored by ArgoCD already)' }}"

    - name: Re-apply all k8s manifests if deployment is missing
      command: kubectl apply -f {{ k8s_manifest_dir }}/
      when: dep_check.rc != 0

    - name: Wait for pod to be Ready
      command: >
        kubectl wait --for=condition=Ready pod
        -l app=dummy-webapp
        -n {{ app_namespace }}
        --timeout=120s
      when: dep_check.rc != 0

    - name: Force ArgoCD hard refresh and sync
      shell: |
        argocd app get {{ argocd_app }} --hard-refresh --grpc-web --insecure 2>/dev/null || true
        argocd app sync {{ argocd_app }} --grpc-web --insecure 2>/dev/null || true
      ignore_errors: true

    - name: Verify health
      uri:
        url: "{{ app_url }}/health"
        method: GET
        status_code: 200
      retries: 12
      delay: 10

    - name: Report
      debug:
        msg: "dummy-webapp restored successfully after Rundeck chaos."
</file>

<file path="ansible/playbooks/fix-traffic-spike.yaml">
---
# Fix Scenario 4: Scale dummy-webapp to 3 replicas to absorb traffic spike.
# Updates deployment.yaml, commits to Gitea, and lets ArgoCD sync.
- name: Fix Traffic Spike — scale webapp replicas
  hosts: local
  gather_facts: false
  vars:
    manifest_path: "{{ playbook_dir }}/../../apps/dummy-webapp/k8s/deployment.yaml"
    target_replicas: 3
    argocd_app: "dummy-webapp"

  tasks:
    - name: Read current Prometheus latency (p95)
      command: >
        kubectl exec -n {{ monitoring_namespace }}
        $(kubectl get pod -n {{ monitoring_namespace }} -l app.kubernetes.io/name=prometheus -o jsonpath='{.items[0].metadata.name}')
        -- wget -qO-
        'http://localhost:9090/api/v1/query?query=histogram_quantile(0.95,rate(webapp_request_latency_seconds_bucket[2m]))'
      register: prom_query
      failed_when: false
      changed_when: false

    - name: Show latency metric
      debug:
        msg: "{{ prom_query.stdout | default('Prometheus query unavailable') }}"

    - name: Patch replicas in deployment manifest
      replace:
        path: "{{ manifest_path }}"
        regexp: '(^\s*replicas:\s*)\d+'
        replace: '\g<1>{{ target_replicas }}'

    - name: Commit scale-out change
      shell: |
        git add {{ manifest_path }}
        git commit -m "fix(traffic): scale dummy-webapp to {{ target_replicas }} replicas"
      args:
        chdir: "{{ playbook_dir }}/../../"

    - name: Push to Gitea
      shell: bash scripts/push-to-gitea.sh
      args:
        chdir: "{{ playbook_dir }}/../../"

    - name: Trigger ArgoCD sync
      command: argocd app sync {{ argocd_app }} --grpc-web --insecure
      ignore_errors: true

    - name: Wait for all replicas to be Ready
      command: >
        kubectl rollout status deployment/dummy-webapp
        -n {{ app_namespace }} --timeout=120s

    - name: Confirm replica count
      command: kubectl get deployment dummy-webapp -n {{ app_namespace }}
      register: dep_status
      changed_when: false

    - name: Report
      debug:
        msg: "Scaled to {{ target_replicas }} replicas. {{ dep_status.stdout }}"
</file>

