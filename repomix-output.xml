        chaos-oom chaos-rundeck chaos-nginx chaos-traffic chaos-db break-things \
        fix-oom fix-rundeck fix-nginx fix-traffic fix-db fix-all \
        _wait-for-pods

MINIKUBE_CPUS     := 4
