# === SECRETS & CERTS (Keep out of source control) ===
*.pem
*.key
*.crt
*.cert
*.pfx
.env*
secrets/
certs/

# === PYTHON ===
__pycache__/
*.py[cod]
*$py.class
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt

